{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri_template",
  "version": "0.1.0",
  "identifier": "com.example.tauri-template",
  "build": {
    "beforeDevCommand": "bash -lc 'if [ -x ./scripts/frontend_dev.sh ]; then ./scripts/frontend_dev.sh; else ../scripts/frontend_dev.sh; fi'",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash -lc 'if [ -x ./scripts/frontend_build.sh ]; then ./scripts/frontend_build.sh; else ../scripts/frontend_build.sh; fi'",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tauri_template",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icons/AppIcon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
